{
  "expo": {
    "name": "TOPO",
    "slug": "topo",
    "version": "2.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "default",
    "icon": "./assets/fixed-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/TOPO_logo_Full.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#23242f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ryester.topo",
      "buildNumber": "20",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "TOPO requires your location to verify when you are at a movie theater to unlock exclusive Digital Ticket Stubs."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/fixed-icon.png",
        "backgroundColor": "#23242f"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "package": "com.ryester.topo",
      "versionCode": 10
    },
    "extra": {
      "eas": {
        "projectId": "baa2a43e-a568-4f77-96d3-23750b05d5bf"
      }
    },
    "owner": "ryester",
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/fixed-icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ]
  }
}